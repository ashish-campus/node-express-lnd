<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>AEdit an Article</title>
</head>
<body class="d-flex flex-column min-vh-100">

    <%- include('partials/header') %>

    <main class="flex-grow-1 container py-4">
        <h2 class="text-center mb-4">Edit an Article</h2>
        <hr>

        <form action="/articles/edit/<%= locals.article._id %>" method="post">
            <div class="mb-3">
                <label for="title" class="form-label">Title:</label>
                <input type="text" name="title" id="title" class="form-control" value="<%= locals.article.title %>">
            </div>
            <div class="mb-3">
                <label for="body" class="form-label">Body:</label>
                <input type="text" name="body" id="body" class="form-control" value="<%= locals.article.body %>">
            </div>
            <button type="submit" class="btn btn-primary">Submit</button>
        </form>
    </main>

    <%- include('partials/footer') %>

</body>
</html>